#!/bin/sh

# Get the diff of commits being pushed
DIFF=$(git diff "origin/$(git branch --show-current)"..HEAD 2>/dev/null || git diff HEAD~1..HEAD 2>/dev/null)

# Nothing to review
if [ -z "$DIFF" ]; then
  exit 0
fi

# Check if gemini is available
if ! command -v gemini >/dev/null 2>&1; then
  echo "[pre-push] WARNING: 'gemini' not found in PATH — skipping security review."
  exit 0
fi

# Find review.js in the skill install location
REVIEW_JS=$(find ~/.claude -name "review.js" -path "*/second-opinion-skill/*" 2>/dev/null | head -1)

if [ -z "$REVIEW_JS" ]; then
  echo "[pre-push] WARNING: review.js not found under ~/.claude — skipping security review."
  exit 0
fi

echo "[pre-push] Running security review via gemini..."

PROMPT="Review this code for security vulnerabilities. Focus on injection, auth, data exposure, input validation, and logic handling untrusted input.

Structure:
**Risk Level**: Critical / High / Medium / Low / None
**Vulnerabilities**: [SEVERITY] description → how to fix
**OK**: What's handled correctly

If no vulnerabilities found, confirm explicitly."

echo "$DIFF" | node "$REVIEW_JS" --engine=gemini "$PROMPT"

# Always exit 0 — show results but never block the push
exit 0
